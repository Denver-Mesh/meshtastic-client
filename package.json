{
  "name": "mesh-client",
  "version": "1.1.3",
  "description": "Cross-platform Meshtastic desktop client - BLE, Serial, HTTP, and MQTT support",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "build:main": "esbuild src/main/index.ts --bundle --platform=node --outfile=dist-electron/main/index.js --external:electron --external:better-sqlite3 --external:electron-updater --external:systeminformation --format=cjs",
    "build:preload": "esbuild src/preload/index.ts --bundle --platform=node --outfile=dist-electron/preload/index.js --external:electron --format=cjs",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "dev": "concurrently \"npm run build:main -- --watch\" \"npm run build:preload -- --watch\" \"vite\" \"node scripts/wait-for-dev.mjs && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "start": "npm run build && electron .",
    "trace-deprecation": "npm run build && NODE_OPTIONS='--trace-deprecation' electron .",
    "postinstall": "electron-builder install-app-deps",
    "prepare": "git config core.hooksPath .githooks",
    "predist": "npm dedupe",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm dedupe && npm run build && electron-builder --mac",
    "dist:linux": "npm dedupe && npm run build && electron-builder --linux",
    "dist:win": "npm dedupe && npm run build && electron-builder --win",
    "test": "vitest",
    "test:run": "vitest run",
    "test:a11y": "vitest run --reporter=verbose"
  },
  "author": {
    "name": "Mesh Contributors",
    "email": "nv0n@coloradomesh.org"
  },
  "contributors": [
    "Joey Stanford https://github.com/rinchen",
    "dude.eth https://github.com/defidude",
    "megabear - KD5IHC"
  ],
  "license": "MIT",
  "keywords": [
    "meshtastic",
    "mesh-network",
    "bluetooth",
    "mqtt",
    "electron",
    "desktop"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Colorado-Mesh/meshtastic-client"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.1",
    "@meshtastic/core": "npm:@jsr/meshtastic__core@^2.6.6",
    "@meshtastic/protobufs": "npm:@jsr/meshtastic__protobufs@^2.7.18",
    "@meshtastic/transport-http": "npm:@jsr/meshtastic__transport-http@^0.2.1",
    "@meshtastic/transport-web-bluetooth": "npm:@jsr/meshtastic__transport-web-bluetooth@^0.1.2",
    "@meshtastic/transport-web-serial": "npm:@jsr/meshtastic__transport-web-serial@^0.2.5",
    "@tailwindcss/postcss": "^4.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-bluetooth": "^0.0.21",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.12",
    "jsdom": "^28.1.0",
    "leaflet": "^1.9.4",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.7.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vitest-axe": "^0.1.0",
    "zustand": "^5.0.0"
  },
  "overrides": {
    "cacheable-request": "^10.0.0",
    "end-of-stream": "1.4.5",
    "minimatch": "10.2.4",
    "once": "1.4.0",
    "pump": "3.0.3",
    "readable-stream": "3.6.2"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "electron-updater": "^6.8.3",
    "mqtt": "^5.15.0",
    "systeminformation": "^5.25.0"
  }
}

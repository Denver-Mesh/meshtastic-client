{
  "name": "mesh-client",
  "version": "5.8.0",
  "description": "Cross-platform Electron desktop client for Meshtastic and MeshCore on macOS, Linux, and Windows — BLE, USB serial, Wi-Fi/TCP, MQTT, local SQLite history, routing diagnostics, and keyboard-first workflows.",
  "keywords": [
    "meshtastic",
    "mesh-network",
    "bluetooth",
    "mqtt",
    "electron",
    "desktop"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Colorado-Mesh/mesh-client"
  },
  "license": "MIT",
  "author": {
    "name": "Colorado Mesh",
    "email": "nv0n@coloradomesh.org"
  },
  "contributors": [
    "Joey Stanford https://github.com/rinchen",
    "dude.eth https://github.com/defidude",
    "megabear - KD5IHC"
  ],
  "main": "dist-electron/main/index.js",
  "scripts": {
    "build": "pnpm run build:main:prod && pnpm run build:preload && pnpm run build:renderer",
    "build:main": "esbuild src/main/index.ts --bundle --platform=node --outfile=dist-electron/main/index.js --external:electron --external:electron-updater --external:systeminformation --external:@stoprocent/noble --external:node-forge --external:jszip --external:mqtt --external:@bufbuild/protobuf --external:@meshtastic/protobufs --format=cjs",
    "build:main:meta": "esbuild src/main/index.ts --bundle --platform=node --outfile=dist-electron/main/index.js --external:electron --external:electron-updater --external:systeminformation --external:@stoprocent/noble --external:node-forge --external:jszip --external:mqtt --external:@bufbuild/protobuf --external:@meshtastic/protobufs --format=cjs --metafile=dist-electron/main/metafile.json",
    "build:main:minify-meta": "esbuild src/main/index.ts --bundle --platform=node --minify --outfile=dist-electron/main/index.js --external:electron --external:electron-updater --external:systeminformation --external:@stoprocent/noble --external:node-forge --external:jszip --external:mqtt --external:@bufbuild/protobuf --external:@meshtastic/protobufs --format=cjs --metafile=dist-electron/main/meta.json",
    "build:main:prod": "esbuild src/main/index.ts --bundle --platform=node --outfile=dist-electron/main/index.js --external:electron --external:electron-updater --external:systeminformation --external:@stoprocent/noble --external:node-forge --external:jszip --external:mqtt --external:@bufbuild/protobuf --external:@meshtastic/protobufs --format=cjs --minify",
    "build:main:size": "node scripts/print-main-bundle-size.mjs",
    "build:preload": "esbuild src/preload/index.ts --bundle --platform=node --outfile=dist-electron/preload/index.js --external:electron --format=cjs",
    "build:renderer": "vite build",
    "check:db-migrations": "node scripts/check-db-migrations.mjs",
    "check:ipc-contract": "node scripts/check-ipc-contract.mjs",
    "check:licenses": "license-checker-rseidelsohn --summary --excludePrivatePackages",
    "check:log-injection": "node scripts/check-log-injection.mjs",
    "clean": "rm -rf dist-electron dist node_modules",
    "dev": "concurrently \"pnpm run build:main --watch\" \"pnpm run build:preload --watch\" \"vite\" \"node scripts/wait-for-dev.mjs && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "predist": "pnpm dedupe",
    "dist": "pnpm run build && electron-builder --publish never",
    "dist:linux": "pnpm dedupe && pnpm run build && electron-builder --linux --x64 --arm64 --publish never",
    "dist:linux:publish": "pnpm dedupe && pnpm run build && electron-builder --linux --x64 --arm64 --publish always",
    "dist:mac": "pnpm dedupe && pnpm run build && electron-builder --mac --publish never",
    "dist:mac:publish": "pnpm dedupe && pnpm run build && electron-builder --mac --publish always",
    "dist:win": "pnpm dedupe && pnpm run build && pnpm install --config.node-linker=hoisted && electron-builder --win --publish never && pnpm install",
    "dist:win:publish": "pnpm dedupe && pnpm run build && pnpm install --config.node-linker=hoisted && electron-builder --win --publish always && pnpm install",
    "docs:build": "node scripts/run-mkdocs.mjs build",
    "docs:install": "node scripts/install-mkdocs-deps.mjs",
    "docs:serve": "node scripts/run-mkdocs.mjs serve",
    "electron:open": "node scripts/start-electron.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md,sh}\" && sort-package-json --ignore \"**/*.md\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md,sh}\" && sort-package-json --check --ignore \"**/*.md\"",
    "preinstall": "pnpm dlx only-allow pnpm",
    "postinstall": "node scripts/rebuild-native.mjs",
    "lint": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs --fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "prepare": "git config core.hooksPath .githooks",
    "rebuild": "node scripts/rebuild-native.mjs",
    "setup:actionlint": "node scripts/install-actionlint.mjs",
    "setup:build-deps": "node scripts/setup-build-deps.mjs",
    "setup:dialout": "node scripts/setup-dialout.mjs",
    "start": "pnpm run build && node scripts/start-electron.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:verbose": "vitest run --reporter=verbose",
    "trace-deprecation": "pnpm run build && NODE_OPTIONS='--trace-deprecation' node scripts/start-electron.mjs",
    "typecheck": "pnpm exec tsc --noEmit && pnpm exec tsc --noEmit -p tsconfig.main.json"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@meshtastic/protobufs": "npm:@jsr/meshtastic__protobufs@^2.7.20",
    "@stoprocent/noble": "^2.4.0",
    "electron-updater": "^6.8.3",
    "jszip": "^3.10.1",
    "mgrs": "^2.1.0",
    "mqtt": "^5.15.1",
    "node-forge": "^1.4.0",
    "systeminformation": "^5.31.5"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.1",
    "@liamcottle/meshcore.js": "^1.13.0",
    "@meshtastic/core": "npm:@jsr/meshtastic__core@^2.6.6",
    "@meshtastic/transport-http": "npm:@jsr/meshtastic__transport-http@^0.2.1",
    "@meshtastic/transport-web-serial": "npm:@jsr/meshtastic__transport-web-serial@^0.2.5",
    "@michaelhart/meshcore-decoder": "^0.2.7",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.19.17",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.2.1",
    "electron": "^40.8.5",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-electron": "^7.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-vitest": "^0.5.4",
    "jsdom": "^25.0.1",
    "leaflet": "^1.9.4",
    "license-checker-rseidelsohn": "^4.4.2",
    "markdownlint-cli2": "^0.22.0",
    "postcss": "^8.5.9",
    "prettier": "^3.8.2",
    "prettier-plugin-sh": "^0.18.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "sort-package-json": "^3.6.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^7.3.2",
    "vitest": "^4.1.4",
    "vitest-axe": "1.0.0-pre.5",
    "zustand": "^5.0.12"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@meshtastic/core",
      "@serialport/bindings-cpp",
      "@stoprocent/bluetooth-hci-socket",
      "@stoprocent/noble",
      "electron",
      "electron-winstaller",
      "esbuild",
      "usb"
    ],
    "overrides": {
      "@typescript-eslint/utils": "^8.58.0",
      "cacheable-request": "^10.0.0",
      "js-yaml": "^4.1.1",
      "lodash": "^4.18.1",
      "lodash-es": "^4.18.1",
      "markdown-it": "^14.1.1",
      "safe-buffer": "^5.2.1",
      "smol-toml": "^1.6.1",
      "tar": "^7.5.11",
      "yauzl": "^3.2.1"
    },
    "patchedDependencies": {
      "@liamcottle/meshcore.js@1.13.0": "patches/@liamcottle__meshcore.js@1.13.0.patch",
      "debug@4.4.3": "patches/debug@4.4.3.patch",
      "readable-stream@4.7.0": "patches/readable-stream@4.7.0.patch"
    },
    "minimumReleaseAgeExclude": [
      "lodash",
      "lodash-es"
    ]
  }
}

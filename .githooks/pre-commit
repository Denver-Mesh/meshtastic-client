#!/bin/sh
# Run format check, lint, and tests before every commit.
# To skip in an emergency: git commit --no-verify

# Ensure locally installed tooling (e.g. `actionlint`) is on PATH.
REPO_ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
if [ -d "$REPO_ROOT/.githooks/bin" ]; then
  export PATH="$REPO_ROOT/.githooks/bin:$PATH"
fi

# Capture paths already staged so we only re-stage those after format. Using
# git add -u would stage every tracked modification and sweep in unstaged WIP.
STAGED_LIST=$(mktemp)
trap 'rm -f "$STAGED_LIST"' EXIT
git diff --cached --name-only --diff-filter=ACM > "$STAGED_LIST" || exit 1

pnpm run format || exit 1
pnpm run lint:md || exit 1

if [ -s "$STAGED_LIST" ]; then
  while IFS= read -r f || [ -n "$f" ]; do
    [ -n "$f" ] || continue
    [ -e "$f" ] || continue
    git add -- "$f" || exit 1
  done < "$STAGED_LIST"
fi

pnpm run lint || exit 1
pnpm run typecheck || exit 1
pnpm run check:log-injection || exit 1
pnpm run check:db-migrations || exit 1
pnpm run check:ipc-contract || exit 1
pnpm audit --audit-level=high || exit 1
actionlint || exit 1
yamllint -f github -s . || exit 1
pnpm run test:run || exit 1
